# Database (Railway подставляет автоматически при подключении PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost/wb_agent

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_ID=your_telegram_user_id_here

# Gemini API (aistudio.google.com → Get API key, формат: AIzaSy...)
GEMINI_API_KEY=your_gemini_key_here

# WB API (получить в личном кабинете WB → Настройки → Доступ к API)
WB_TOKEN=

# Railway (проставляется автоматически при деплое — не трогать)
RAILWAY_PUBLIC_DOMAIN=
